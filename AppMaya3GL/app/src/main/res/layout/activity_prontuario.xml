<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FA"
    tools:context=".ProntuarioActivity">

    <LinearLayout
        android:id="@+id/ll_header_prontuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_titulo_prontuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meu Prontuário"
            android:textColor="@color/maya_marrom_escuro"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_subtitulo_prontuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Histórico de avaliações e relatórios clínicos."
            android:textColor="#78909C"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_view_prontuarios"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_header_prontuario">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_prontuario_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_icon_doc_1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:scaleType="center"
                        android:src="@drawable/ic_report_doc"
                        app:backgroundTint="#E0F7FA"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
                        app:tint="@color/maya_ciano" />

                    <TextView
                        android:id="@+id/tv_data_prontuario_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="15/05/2024"
                        android:textColor="#78909C"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_doc_1"
                        app:layout_constraintTop_toTopOf="@id/iv_icon_doc_1" />

                    <TextView
                        android:id="@+id/tv_tipo_prontuario_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Avaliação Postural Inicial (RPG)"
                        android:textColor="@color/maya_marrom_escuro"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/tv_data_prontuario_1"
                        app:layout_constraintTop_toBottomOf="@id/tv_data_prontuario_1" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Profissional: Maya Yamamoto"
                        android:textColor="#37474F"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/tv_data_prontuario_1"
                        app:layout_constraintTop_toBottomOf="@id/tv_tipo_prontuario_1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download_relatorio_1"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingHorizontal="16dp"
                        android:text="BAIXAR RELATÓRIO"
                        android:textColor="@color/maya_ciano"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_download"
                        app:iconSize="18dp"
                        app:iconTint="@color/maya_ciano"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/iv_icon_doc_1"
                        app:strokeColor="#E0E0E0" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_prontuario_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_icon_doc_2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:scaleType="center"
                        android:src="@drawable/ic_report_doc"
                        app:backgroundTint="#FFF0ED"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
                        app:tint="@color/maya_terracota" />

                    <TextView
                        android:id="@+id/tv_data_prontuario_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="28/05/2024"
                        android:textColor="#78909C"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/iv_icon_doc_2"
                        app:layout_constraintTop_toTopOf="@id/iv_icon_doc_2" />

                    <TextView
                        android:id="@+id/tv_tipo_prontuario_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Relatório de Evolução Mensal"
                        android:textColor="@color/maya_marrom_escuro"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/tv_data_prontuario_2"
                        app:layout_constraintTop_toBottomOf="@id/tv_data_prontuario_2" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Profissional: Maya Yamamoto"
                        android:textColor="#37474F"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/tv_data_prontuario_2"
                        app:layout_constraintTop_toBottomOf="@id/tv_tipo_prontuario_2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download_relatorio_2"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingHorizontal="16dp"
                        android:text="BAIXAR RELATÓRIO"
                        android:textColor="@color/maya_ciano"
                        android:textSize="12sp"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/ic_download"
                        app:iconSize="18dp"
                        app:iconTint="@color/maya_ciano"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/iv_icon_doc_2"
                        app:strokeColor="#E0E0E0" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>