<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Imagem da Maya no fundo -->
    <ImageView
        android:id="@+id/iv_maya_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/maya_fundo" />

    <View
        android:id="@+id/view_dark_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A6000000" /> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp">

    <ImageView
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:adjustViewBounds="true"
        android:src="@drawable/maya_logo" /> <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Bem-vindo(a) à Maya RPG"
    android:textAlignment="center"
    android:textColor="@color/white"
    android:textSize="24sp"
    android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Especialista em Reeducação Postural Global. Transformando vidas através do movimento consciente e alívio das dores."
        android:textAlignment="center"
        android:textColor="#E0E0E0"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_agendar_inicial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <ImageView
                android:id="@+id/iv_icon_agendar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_calendar_add"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/maya_ciano" />

            <TextView
                android:id="@+id/tv_title_agendar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Agendar Avaliação"
                android:textColor="@color/maya_marrom_escuro"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_icon_agendar"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Comece seu tratamento escolhendo a melhor data."
                android:textColor="#78909C"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@id/tv_title_agendar"
                app:layout_constraintStart_toStartOf="@id/tv_title_agendar"
                app:layout_constraintTop_toBottomOf="@id/tv_title_agendar" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_area_paciente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <ImageView
                android:id="@+id/iv_icon_paciente"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_history"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/maya_terracota" />

            <TextView
                android:id="@+id/tv_title_paciente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Área do Paciente"
                android:textColor="@color/maya_marrom_escuro"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_icon_paciente"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Acesse seu painel com histórico, exercícios e prontuários."
                android:textColor="#78909C"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@id/tv_title_paciente"
                app:layout_constraintStart_toStartOf="@id/tv_title_paciente"
                app:layout_constraintTop_toBottomOf="@id/tv_title_paciente" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_seja_paciente"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:text="Ainda não é paciente? Cadastre-se"
        android:textColor="#E0E0E0"
        android:textSize="12sp"
        app:rippleColor="#40FFFFFF" />

</LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>