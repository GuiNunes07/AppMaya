<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E24"
    tools:context=".activityCadastro">
    <!-- O fundo #1E1E24 simula a foto escurecida -->

    <TextView
        android:id="@+id/btn_voltarCadastro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:text="Voltar"
        android:textColor="@color/maya_ciano"
        android:textSize="14sp"
        android:textStyle="bold"
        app:drawableStartCompat="@drawable/ic_arrow_back"
        app:drawableTint="@color/maya_ciano"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- ScrollView permite rolar a tela quando o teclado abrir -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_voltarCadastro">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- LOGO MAYA RPG -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Maya RPG"
                android:textAlignment="center"
                android:textColor="@color/maya_ciano"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="YAMAMOTO RPG"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"/>

            <!-- TÍTULO CADASTRE-SE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="CADASTRE-SE:"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="E tenha um conforto perfeito!"
                android:textAlignment="center"
                android:textColor="#E0E0E0"
                android:textSize="14sp" />

            <!-- CAMPO: USUÁRIO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Usuário:"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_usuario_cadastro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_branco"
                android:hint="Digite seu usuário"
                android:paddingHorizontal="16dp"
                android:textColor="#000000"
                android:textColorHint="#9E9E9E"
                android:textSize="14sp" />

            <!-- CAMPO: E-MAIL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="E-mail:"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_email_cadastro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_branco"
                android:hint="Digite seu e-mail"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="#000000"
                android:textColorHint="#9E9E9E"
                android:textSize="14sp" />

            <!-- CAMPO: SENHA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Digite sua senha:"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_senha_cadastro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_branco"
                android:hint="Digite sua senha"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="#000000"
                android:textColorHint="#9E9E9E"
                android:textSize="14sp" />

            <!-- CAMPO: CONFIRMAR SENHA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Confirme sua senha:"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_confirmar_senha_cadastro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_branco"
                android:hint="Digite sua senha"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="#000000"
                android:textColorHint="#9E9E9E"
                android:textSize="14sp" />

            <!-- BOTÃO CONFIRMAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirmar_cadastro"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="24dp"
                android:paddingHorizontal="48dp"
                android:text="CONFIRMAR"
                android:textColor="#000000"
                android:textStyle="bold"
                app:backgroundTint="@color/maya_ciano"
                app:cornerRadius="28dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>